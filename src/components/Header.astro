---
const navLinks = [
  { label: 'Gear', href: '/gear/' },
  { label: 'Hiking', href: '/hiking/' },
  { label: 'Camping', href: '/camping/' },
  { label: 'Safety', href: '/safety/' },
  { label: 'Destinations', href: '/destinations/' },
  { label: 'About', href: '/about/' },
];
---

<header class="border-b border-gray-200 bg-white sticky top-0 z-50">
  <nav class="max-w-6xl mx-auto px-4 py-4 flex items-center justify-between">
    <a href="/" class="font-heading text-2xl font-800 text-forest">
      FidoHikes
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-6 text-sm font-medium">
      {navLinks.map((link) => (
        <li>
          <a href={link.href} class="text-gray-600 hover:text-forest transition-colors">
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Mobile hamburger button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 text-gray-600 hover:text-forest"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg id="menu-open-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
      <svg id="menu-close-icon" class="w-6 h-6 hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
      </svg>
    </button>
  </nav>

  <!-- Mobile dropdown menu -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-gray-100 bg-white">
    <ul class="px-4 py-3 space-y-1">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class="block py-2 px-3 rounded-md text-gray-700 hover:bg-gray-50 hover:text-forest transition-colors font-medium"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const openIcon = document.getElementById('menu-open-icon');
  const closeIcon = document.getElementById('menu-close-icon');

  btn?.addEventListener('click', () => {
    const isOpen = menu?.classList.toggle('hidden') === false;
    openIcon?.classList.toggle('hidden', isOpen);
    closeIcon?.classList.toggle('hidden', !isOpen);
    btn.setAttribute('aria-expanded', String(isOpen));
  });
</script>
