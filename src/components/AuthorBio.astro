---
interface Props {
  variant?: 'compact' | 'full';
}

const { variant = 'compact' } = Astro.props;
---

{variant === 'full' ? (
  <div class="bg-white rounded-xl border border-sand p-6 md:p-8">
    <div class="flex flex-col sm:flex-row gap-5 items-start">
      <img
        src="/images/about/logo-photo.jpg"
        alt="Toby on the Appalachian Trail"
        class="w-20 h-20 rounded-full object-cover border-2 border-trail-light flex-shrink-0"
        loading="lazy"
      />
      <div>
        <p class="font-heading font-700 text-earth text-lg">Trail-Tested with Toby</p>
        <p class="mt-1 text-earth-light leading-relaxed">
          Everything on FidoHikes comes from real experience — 900 miles on the Appalachian Trail with our dog Toby.
          No sponsored posts, no armchair advice. Just what actually worked (and what didn't) on the trail.
        </p>
        <a href="/about/" class="inline-block mt-3 text-sm font-ui font-medium text-forest hover:text-forest-dark transition-colors">
          Read our story &rarr;
        </a>
      </div>
    </div>
  </div>
) : (
  <div class="flex items-center gap-3">
    <img
      src="/images/about/logo-photo.jpg"
      alt="Toby on the Appalachian Trail"
      class="w-10 h-10 rounded-full object-cover border border-trail-light"
      loading="lazy"
    />
    <div class="font-ui text-sm">
      <span class="font-medium text-earth">FidoHikes</span>
      <span class="text-gray-400 mx-1">·</span>
      <span class="text-gray-500">900 miles on the AT with Toby</span>
    </div>
  </div>
)}
