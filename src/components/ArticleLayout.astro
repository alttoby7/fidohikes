---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import ArticleSchema from '@/components/schema/ArticleSchema.astro';
import FAQSchema from '@/components/schema/FAQSchema.astro';
import AffiliateDisclosure from '@/components/affiliate/AffiliateDisclosure.astro';
import { getBreadcrumbs, getRelatedPages } from '@/lib/registry';
import type { Page } from '@/lib/registry';

interface Props {
  page: Page;
}

const { page } = Astro.props;
const { data } = page;
const breadcrumbs = await getBreadcrumbs(page);
const related = await getRelatedPages(page);
const showAffiliate = data.affiliate?.enabled ?? false;
---

<BaseLayout
  title={data.seo?.metaTitle ?? data.title}
  description={data.seo?.metaDescription ?? data.excerpt}
  ogImage={data.seo?.ogImage ?? data.heroImage}
  type="article"
  publishedDate={data.publishedDate}
  updatedDate={data.updatedDate}
>
  <BreadcrumbSchema items={breadcrumbs} />
  <ArticleSchema page={page} />
  {data.faqs.length > 0 && <FAQSchema faqs={data.faqs} />}

  <article class="max-w-4xl mx-auto px-4 py-8">
    <!-- Breadcrumbs -->
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-6">
      <ol class="flex flex-wrap gap-1">
        {breadcrumbs.map((crumb, i) => (
          <li class="flex items-center gap-1">
            {i > 0 && <span class="text-gray-300">/</span>}
            {i < breadcrumbs.length - 1 ? (
              <a href={crumb.href} class="hover:text-forest">{crumb.label}</a>
            ) : (
              <span class="text-gray-700">{crumb.label}</span>
            )}
          </li>
        ))}
      </ol>
    </nav>

    <!-- Title -->
    <h1 class="font-heading text-3xl md:text-4xl font-800 text-earth mb-4">
      {data.title}
    </h1>

    {data.excerpt && (
      <p class="text-lg text-gray-600 mb-6">{data.excerpt}</p>
    )}

    {data.publishedDate && (
      <div class="text-sm text-gray-400 mb-8">
        Published {data.publishedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
        {data.updatedDate && (
          <span> · Updated {data.updatedDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
        )}
      </div>
    )}

    {showAffiliate && <AffiliateDisclosure />}

    <!-- Hero image -->
    {data.heroImage && (
      <img
        src={data.heroImage}
        alt={data.title}
        class="w-full rounded-lg mb-8"
        loading="eager"
      />
    )}

    <!-- Content -->
    <div class="prose">
      <slot />
    </div>

    <!-- FAQs -->
    {data.faqs.length > 0 && (
      <section class="mt-12 border-t border-gray-200 pt-8">
        <h2 class="font-heading text-2xl font-700 text-earth mb-6">Frequently Asked Questions</h2>
        <dl class="space-y-6">
          {data.faqs.map((faq) => (
            <div>
              <dt class="font-semibold text-gray-900">{faq.question}</dt>
              <dd class="mt-2 text-gray-600">{faq.answer}</dd>
            </div>
          ))}
        </dl>
      </section>
    )}

    <!-- Related articles -->
    {related.length > 0 && (
      <section class="mt-12 border-t border-gray-200 pt-8">
        <h2 class="font-heading text-2xl font-700 text-earth mb-6">Related Articles</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {related.map((r) => (
            <a
              href={`/${r.data.slug}/`}
              class="block p-4 rounded-lg border border-gray-200 hover:border-forest hover:shadow-sm transition-all"
            >
              <h3 class="font-semibold text-gray-900">{r.data.title}</h3>
              {r.data.excerpt && <p class="mt-1 text-sm text-gray-500 line-clamp-2">{r.data.excerpt}</p>}
            </a>
          ))}
        </div>
      </section>
    )}
  </article>
</BaseLayout>
