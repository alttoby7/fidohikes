---
interface Props {
  question: string;
}

const { question } = Astro.props;
---

<details class="border border-gray-200 rounded-lg my-3 group">
  <summary class="px-4 py-3 cursor-pointer font-medium text-gray-900 hover:bg-gray-50">
    {question}
  </summary>
  <div class="px-4 pb-4 text-gray-600 text-sm">
    <slot />
  </div>
</details>
