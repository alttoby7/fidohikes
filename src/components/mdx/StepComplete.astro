---
interface Props {
  step: number;
  title: string;
}

const { step, title } = Astro.props;
---

<div class="flex items-start gap-4 my-6">
  <div class="flex-shrink-0 w-8 h-8 rounded-full bg-forest text-white flex items-center justify-center text-sm font-bold">
    {step}
  </div>
  <div>
    <h3 class="font-semibold text-gray-900 mb-1">{title}</h3>
    <div class="text-gray-600">
      <slot />
    </div>
  </div>
</div>
