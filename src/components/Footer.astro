---
const year = new Date().getFullYear();
const footerLinks = [
  { label: 'About', href: '/about/' },
  { label: 'Contact', href: '/contact/' },
  { label: 'Privacy Policy', href: '/privacy-policy/' },
  { label: 'Affiliate Disclosure', href: '/affiliate-disclosure/' },
  { label: 'Editorial Policy', href: '/editorial-policy/' },
];
---

<footer class="bg-gray-50 border-t border-gray-200 mt-16">
  <div class="max-w-6xl mx-auto px-4 py-12">
    <div class="flex flex-col md:flex-row justify-between gap-8">
      <div>
        <a href="/" class="font-heading text-xl font-700 text-forest">FidoHikes</a>
        <p class="mt-2 text-sm text-gray-500 max-w-xs">
          Gear reviews, trail guides, and everything you need for outdoor adventures with your dog.
        </p>
      </div>
      <nav>
        <ul class="flex flex-wrap gap-x-6 gap-y-2 text-sm">
          {footerLinks.map((link) => (
            <li>
              <a href={link.href} class="text-gray-500 hover:text-forest transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
    <p class="mt-8 text-xs text-gray-400">
      &copy; {year} FidoHikes. All rights reserved.
    </p>
  </div>
</footer>
