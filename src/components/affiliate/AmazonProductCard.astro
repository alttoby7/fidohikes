---
import {
  getAffiliateHref,
  getAffiliateProduct,
  type AffiliateHrefOptions,
} from '@/lib/affiliate';

interface Props {
  product: string;
  ctaText?: string;
  placement?: AffiliateHrefOptions['placement'];
  trackingBucket?: AffiliateHrefOptions['trackingBucket'];
  destinationMode?: AffiliateHrefOptions['destinationMode'];
}

const {
  product,
  ctaText = 'Check price on Amazon',
  placement = 'article-card',
  trackingBucket,
  destinationMode = 'amazon',
} = Astro.props;

const affiliateProduct = getAffiliateProduct(product);
if (!affiliateProduct) {
  throw new Error(`Unknown affiliate product "${product}"`);
}

const articleSlug = Astro.url.pathname.replace(/^\/|\/$/g, '') || undefined;
const href = getAffiliateHref(product, {
  placement,
  trackingBucket,
  destinationMode,
  linkType: 'card',
  articleSlug,
  ctaText,
});
---

<aside class="my-8 overflow-hidden rounded-2xl border border-sand bg-white shadow-sm">
  <div class="grid gap-4 p-5 sm:grid-cols-[140px_1fr] sm:items-center">
    <div class="overflow-hidden rounded-xl bg-parchment p-3">
      <img
        src={affiliateProduct.image}
        alt={affiliateProduct.title}
        class="h-32 w-full object-contain"
        loading="lazy"
      />
    </div>
    <div>
      <div class="mb-2 flex flex-wrap items-center gap-2">
        <span class="rounded-full bg-trail-light/20 px-2 py-1 font-ui text-[11px] font-semibold uppercase tracking-wide text-earth">
          Paid link
        </span>
        <span class="font-ui text-xs uppercase tracking-wide text-earth-light">
          {affiliateProduct.category}
        </span>
      </div>
      <h3 class="font-heading text-xl font-700 text-earth">{affiliateProduct.title}</h3>
      <div class="mt-4">
        <a
          href={href}
          target="_blank"
          rel="nofollow noopener sponsored"
          class="inline-flex items-center rounded-lg border border-forest px-4 py-2 font-ui text-sm font-semibold text-forest transition-colors hover:bg-forest hover:text-white"
        >
          {ctaText}
        </a>
      </div>
    </div>
  </div>
</aside>
