---
interface Props {
  name: string;
  image?: string;
  price?: string;
  rating?: number;
  url: string;
  description?: string;
  badge?: string;
}

const { name, image, price, rating, url, description, badge } = Astro.props;
---

<div class="border border-gray-200 rounded-lg p-4 hover:shadow-md transition-shadow">
  {badge && (
    <span class="inline-block bg-forest text-white text-xs font-semibold px-2 py-1 rounded mb-2">
      {badge}
    </span>
  )}
  {image && (
    <img src={image} alt={name} class="w-full h-48 object-contain mb-3" loading="lazy" />
  )}
  <h3 class="font-semibold text-gray-900">{name}</h3>
  {description && <p class="text-sm text-gray-600 mt-1">{description}</p>}
  <div class="flex items-center justify-between mt-3">
    <div class="flex items-center gap-2">
      {rating !== undefined && (
        <span class="text-sm text-amber-500 font-medium">{rating}/5</span>
      )}
      {price && <span class="text-sm font-semibold text-gray-900">{price}</span>}
    </div>
    <a
      href={url}
      target="_blank"
      rel="nofollow noopener sponsored"
      class="bg-forest text-white text-sm font-medium px-4 py-2 rounded hover:bg-forest-dark transition-colors"
    >
      Check Price
    </a>
  </div>
</div>
