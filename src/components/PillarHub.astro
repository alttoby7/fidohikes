---
import BaseLayout from '@/layouts/BaseLayout.astro';
import BreadcrumbSchema from '@/components/schema/BreadcrumbSchema.astro';
import { getClustersByPillar, getPagesByPillar, getPagesByCluster } from '@/lib/registry';
import type { Pillar } from '@/lib/registry';

interface Props {
  pillar: Pillar;
}

const { pillar } = Astro.props;
const { data } = pillar;
const clusters = await getClustersByPillar(data.slug);
const allPages = await getPagesByPillar(data.slug);

// Build cluster → articles map
const clusterArticles = new Map<string, typeof allPages>();
for (const cluster of clusters) {
  const articles = await getPagesByCluster(cluster.data.slug);
  clusterArticles.set(cluster.data.slug, articles);
}

// Unclustered pages (pillar-level pages not in any cluster)
const clusteredSlugs = new Set(
  [...clusterArticles.values()].flat().map((p) => p.data.slug)
);
const unclustered = allPages.filter((p) => !clusteredSlugs.has(p.data.slug));

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: data.name, href: `/${data.slug}/` },
];
---

<BaseLayout title={data.name} description={data.description}>
  <BreadcrumbSchema items={breadcrumbs} />

  <div class="max-w-4xl mx-auto px-4 py-8">
    <nav aria-label="Breadcrumb" class="text-sm text-gray-500 mb-6">
      <ol class="flex gap-1">
        <li><a href="/" class="hover:text-forest">Home</a></li>
        <li class="flex items-center gap-1">
          <span class="text-gray-300">/</span>
          <span class="text-gray-700">{data.name}</span>
        </li>
      </ol>
    </nav>

    <h1 class="font-heading text-3xl md:text-4xl font-800 text-earth mb-4">{data.name}</h1>
    <p class="text-lg text-earth-light mb-10">{data.description}</p>

    {clusters.map((cluster) => {
      const articles = clusterArticles.get(cluster.data.slug) ?? [];
      return (
        <section class="mb-12">
          <div class="flex items-baseline gap-3 mb-4">
            <h2 class="font-heading text-xl font-700 text-earth">
              {cluster.data.name}
            </h2>
            {articles.length > 0 && (
              <span class="font-ui text-xs font-medium text-trail bg-trail-light/20 px-2 py-0.5 rounded-full">{articles.length}</span>
            )}
          </div>
          <p class="text-earth-light mb-5">{cluster.data.description}</p>
          {articles.length > 0 && (
            <div class="grid sm:grid-cols-2 gap-4">
              {articles.map((article) => (
                <a
                  href={`/${article.data.slug}/`}
                  class="block bg-white border border-sand rounded-lg overflow-hidden hover:border-forest hover:shadow-sm transition-all group"
                >
                  {article.data.heroImage && (
                    <img src={article.data.heroImage} alt={article.data.title} class="w-full h-32 object-cover" loading="lazy" />
                  )}
                  <div class="p-4">
                    <h3 class="font-heading text-sm font-700 text-earth group-hover:text-forest transition-colors">
                      {article.data.title}
                    </h3>
                    {article.data.excerpt && (
                      <p class="mt-1 text-sm text-earth-light line-clamp-2">{article.data.excerpt}</p>
                    )}
                  </div>
                </a>
              ))}
            </div>
          )}
        </section>
      );
    })}

    {unclustered.length > 0 && (
      <section class="mb-12">
        <h2 class="font-heading text-xl font-700 text-earth mb-5">More Articles</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {unclustered.map((article) => (
            <a
              href={`/${article.data.slug}/`}
              class="block bg-white border border-sand rounded-lg overflow-hidden hover:border-forest hover:shadow-sm transition-all group"
            >
              {article.data.heroImage && (
                <img src={article.data.heroImage} alt={article.data.title} class="w-full h-32 object-cover" loading="lazy" />
              )}
              <div class="p-4">
                <h3 class="font-heading text-sm font-700 text-earth group-hover:text-forest transition-colors">
                  {article.data.title}
                </h3>
                {article.data.excerpt && (
                  <p class="mt-1 text-sm text-earth-light line-clamp-2">{article.data.excerpt}</p>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</BaseLayout>
