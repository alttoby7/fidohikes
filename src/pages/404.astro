---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <div class="max-w-2xl mx-auto px-4 py-24 text-center">
    <h1 class="font-heading text-6xl font-800 text-gray-300 mb-4">404</h1>
    <p class="text-xl text-gray-600 mb-8">
      Looks like this trail doesn't exist. Your dog probably wandered off-path.
    </p>
    <a href="/" class="bg-forest text-white px-6 py-3 rounded-lg font-medium hover:bg-forest-dark transition-colors">
      Back to Home
    </a>
  </div>
</BaseLayout>
