---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const pillars = await getCollection('pillars');
const sortedPillars = pillars.sort((a, b) => a.data.order - b.data.order);
const pages = await getCollection('pages');
const publishedCount = pages.filter((p) => p.data.status === 'published').length;
---

<BaseLayout title="FidoHikes — Hiking & Camping with Your Dog">
  <!-- Hero -->
  <section class="relative min-h-[70vh] flex items-center justify-center overflow-hidden">
    <img
      src="/images/about/backpacking-with-dog.jpg"
      alt="Backpacking on the Appalachian Trail with Toby"
      class="absolute inset-0 w-full h-full object-cover"
      loading="eager"
    />
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/40 to-black/20"></div>
    <div class="relative max-w-4xl mx-auto px-4 text-center py-16">
      <p class="font-ui text-sm uppercase tracking-widest text-trail-light mb-4">900 miles on the Appalachian Trail with our dog Toby</p>
      <h1 class="font-heading text-4xl md:text-5xl lg:text-6xl font-800 text-white mb-6 leading-tight">
        Every Trail Lesson<br />We Learned
      </h1>
      <p class="text-lg md:text-xl text-white/80 max-w-2xl mx-auto mb-8">
        Real gear reviews, trail guides, and safety tips from 900 miles of hiking the AT with a dog. No sponsored posts — just what actually worked.
      </p>
      <div class="flex flex-wrap justify-center gap-3">
        <a href="/gear/" class="bg-forest text-white px-6 py-3 rounded-lg font-ui font-medium hover:bg-forest-dark transition-colors">
          Browse Gear
        </a>
        <a href="/about/" class="border border-white/40 text-white px-6 py-3 rounded-lg font-ui font-medium hover:bg-white/10 transition-colors">
          Our Story
        </a>
      </div>
    </div>
  </section>

  <!-- Pillars -->
  <section class="max-w-6xl mx-auto px-4 py-16">
    <h2 class="font-heading text-2xl md:text-3xl font-700 text-earth text-center mb-10">
      Explore by Topic
    </h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {sortedPillars.map((pillar) => (
        <a
          href={`/${pillar.data.slug}/`}
          class="block p-6 rounded-xl bg-white border border-sand hover:border-forest hover:shadow-md transition-all group"
        >
          <h3 class="font-heading text-lg font-700 text-earth group-hover:text-forest transition-colors">
            {pillar.data.name}
          </h3>
          <p class="mt-2 text-sm text-earth-light">{pillar.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
