---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Contact" description="Get in touch with the FidoHikes team.">
  <article class="max-w-3xl mx-auto px-4 py-12">
    <h1 class="font-heading text-3xl md:text-4xl font-800 text-earth mb-6">Contact Us</h1>
    <div class="prose">
      <p>
        Have a question, suggestion, or want to collaborate? We'd love to hear from you.
      </p>
      <p>
        Email us at <a href="mailto:hello@fidohikes.com">hello@fidohikes.com</a>
      </p>
      <h2>Product Reviews</h2>
      <p>
        If you're a brand interested in having your product reviewed, please include product details,
        your website, and what makes your product great for trail dogs.
      </p>
      <h2>Corrections</h2>
      <p>
        Found an error in one of our articles? Let us know and we'll fix it promptly.
      </p>
    </div>
  </article>
</BaseLayout>
